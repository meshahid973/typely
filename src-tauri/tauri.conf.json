{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typely",
  "version": "0.4.0",
  "identifier": "com.meshahid973.typely",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Typely",
        "width": 1120,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https://*.workers.dev https://*.typely.app https://api.github.com",
        "img-src": "'self' data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/128x128.png", "icons/128x128@2x.png"]
  }
}
