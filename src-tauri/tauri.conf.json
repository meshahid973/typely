{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typely",
  "version": "0.1.0",
  "identifier": "com.meshahid973.typely",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Typely",
        "width": 1120,
        "height": 720,
        "minWidth": 780,
        "minHeight": 540,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/128x128.png", "icons/128x128@2x.png"]
  }
}
